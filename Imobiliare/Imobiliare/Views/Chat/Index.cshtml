@model List<Imobiliare.Models.Conversatie>

@{
    ViewData["Title"] = "Mesagerie";
    int currentUserId = ViewBag.CurrentUserId;
    int? activeId = ViewBag.ActiveConversationId;

    var activeChat = Model.FirstOrDefault(c => c.ID_Conversatie == activeId);
}

<style>
    html, body {
        height: 100%;
        margin: 0;
        overflow: hidden;
    }

    body {
        padding-top: 70px !important; /* cat are navbarul tau */
    }

    .chat-page {
        height: calc(100vh - 70px);
        overflow: hidden;
        background: linear-gradient(135deg, #ffe8f6 0%, #f7e2ff 45%, #e7f7ff 100%);
        padding-top: 0;
        padding-bottom: 0;
    }

        .chat-page .container {
            padding: 0 !important;
        }

            .chat-page .container.py-4 {
                padding-top: 0 !important;
                padding-bottom: 0 !important;
            }

    .chat-wrapper {
        height: calc(100vh - 70px);
        margin-top: 0;
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-radius: 30px;
        overflow: hidden;
        display: flex;
        box-shadow: 0 20px 50px rgba(166, 91, 166, 0.18);
        border: 1px solid rgba(255,255,255,0.45);
    }

    /* SIDEBAR */
    .chat-sidebar {
        width: 360px;
        min-width: 360px;
        height: 100%;
        background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(252,245,255,0.92));
        border-right: 1px solid #f0e4f5;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .sidebar-header {
        padding: 24px 22px;
        border-bottom: 1px solid #f3e7f7;
        background: rgba(255,255,255,0.8);
        flex-shrink: 0;
    }

        .sidebar-header h4 {
            color: #C33FC3 !important;
            font-weight: 800;
            font-size: 1.4rem;
            margin: 0;
        }

    .conversation-list {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 10px;
        min-height: 0;
    }

    .conv-item {
        padding: 14px;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.28s ease;
        display: flex;
        align-items: center;
        border-radius: 22px;
        margin-bottom: 10px;
        background: transparent;
    }

        .conv-item:hover {
            background: linear-gradient(135deg, #fff8fd, #f7f2ff);
            transform: translateX(4px);
            border-color: #f0d9f7;
            box-shadow: 0 8px 20px rgba(195, 63, 195, 0.08);
        }

        .conv-item.active {
            background: linear-gradient(135deg, rgba(195,63,195,0.10), rgba(117,197,203,0.12));
            border: 1px solid rgba(195, 63, 195, 0.18);
            box-shadow: 0 10px 24px rgba(195, 63, 195, 0.10);
            position: relative;
        }

            .conv-item.active::before {
                content: "";
                position: absolute;
                left: -2px;
                top: 12px;
                bottom: 12px;
                width: 5px;
                border-radius: 10px;
                background: linear-gradient(to bottom, #C33FC3, #75c5cb);
            }

    .user-avatar {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #75c5cb, #C33FC3);
        color: white;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.15rem;
        margin-right: 14px;
        flex-shrink: 0;
        box-shadow: 0 8px 18px rgba(195, 63, 195, 0.18);
    }

    /* MAIN CHAT */
    .chat-main {
        flex: 1;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: linear-gradient(180deg, #fffefe, #fcfbff);
        overflow: hidden;
        min-width: 0;
    }

    .chat-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f2e8f5;
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(12px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

        .chat-header h5 {
            color: #C33FC3;
            font-weight: 800;
            margin: 0 0 4px 0;
        }

        .chat-header small,
        .chat-header a {
            color: #8b7b92;
        }

    .messages-container {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 25px;
        background: radial-gradient(circle at top left, rgba(255,255,255,0.6), transparent 30%), url("https://www.transparenttextures.com/patterns/cubes.png");
        background-color: #fcf8fd;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .msg-bubble {
        max-width: 72%;
        padding: 13px 17px 10px;
        border-radius: 22px;
        position: relative;
        font-size: 0.96rem;
        line-height: 1.45;
        box-shadow: 0 6px 18px rgba(0,0,0,0.05);
        word-break: break-word;
        animation: msgFadeUp 0.25s ease;
    }

    @@keyframes msgFadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .msg-me {
        align-self: flex-end;
        background: linear-gradient(135deg, #C33FC3, #de63de);
        color: white;
        border-radius: 22px 22px 6px 22px;
    }

    .msg-them {
        align-self: flex-start;
        background: rgba(255,255,255,0.96);
        color: #333;
        border: 1px solid #efe6f2;
        border-radius: 22px 22px 22px 6px;
    }

    .msg-time {
        font-size: 0.72rem;
        margin-top: 6px;
        opacity: 0.75;
        text-align: right;
        display: block;
    }

    .msg-me .msg-time {
        color: rgba(255,255,255,0.85);
    }

    .msg-them .msg-time {
        color: #9c8da4;
    }

    .chat-footer {
        padding: 18px;
        background: rgba(255,255,255,0.9);
        border-top: 1px solid #f2e7f4;
        flex-shrink: 0;
    }

        .chat-footer form {
            display: flex;
            gap: 12px;
            align-items: center;
            margin: 0;
        }

        .chat-footer input[type="text"] {
            border-radius: 18px !important;
            border: 2px solid #f2e7f4 !important;
            background: #fff !important;
            padding: 12px 18px !important;
            box-shadow: none !important;
        }

            .chat-footer input[type="text"]:focus {
                border-color: #75c5cb !important;
                box-shadow: 0 0 0 0.22rem rgba(117, 197, 203, 0.16) !important;
            }

        .chat-footer button {
            width: 48px !important;
            height: 48px !important;
            border-radius: 16px !important;
            border: none !important;
            background: linear-gradient(135deg, #75c5cb, #59b8c1) !important;
            box-shadow: 0 8px 16px rgba(117, 197, 203, 0.26);
            transition: 0.28s ease;
        }

            .chat-footer button:hover {
                background: linear-gradient(135deg, #C33FC3, #db54db) !important;
                transform: translateY(-1px) scale(1.04);
            }

    .conversation-list::-webkit-scrollbar,
    .messages-container::-webkit-scrollbar {
        width: 7px;
    }

    .conversation-list::-webkit-scrollbar-thumb,
    .messages-container::-webkit-scrollbar-thumb {
        background: linear-gradient(to bottom, #eed7f7, #d9edf1);
        border-radius: 20px;
    }

    @@media (max-width: 992px) {
        html, body {
            overflow: auto;
        }

        .chat-page {
            height: auto;
            min-height: calc(100vh - 70px);
        }

        .chat-wrapper {
            flex-direction: column;
            height: auto;
        }

        .chat-sidebar {
            width: 100%;
            min-width: 100%;
            max-height: 320px;
        }

        .msg-bubble {
            max-width: 88%;
        }

        main {
            height: calc(100vh - 70px);
            overflow: hidden;
        }
    }
</style>
<div class="chat-page"> 
    <div class="container h-100">

    <div class="chat-wrapper">

        <div class="chat-sidebar">
            <div class="sidebar-header">
                <h4 class="fw-bold m-0 text-primary">Mesaje</h4>
            </div>

            <div class="conversation-list">
                @if (!Model.Any())
                {
                    <div class="text-center p-4 text-muted">Nu ai conversații active.</div>
                }

                @foreach (var conv in Model)
                {
                    // Determinam cine este partenerul de discutie
                    // Daca eu sunt clientul, partenerul e proprietarul. Altfel invers.
                    var partener = (conv.ID_Utilizator_client == currentUserId)
                    ? conv.Utilizator_proprietar
                    : conv.Utilizator_client;

                    string activeClass = (conv.ID_Conversatie == activeId) ? "active" : "";
                    string partenerNume = partener != null ? $"{partener.Nume} {partener.Prenume}" : "Utilizator șters";

                    <a href="@Url.Action("Index", new { idConversatieActiva = conv.ID_Conversatie })" class="text-decoration-none text-dark">
                        <div class="conv-item @activeClass">
                            <div class="user-avatar">
                                @(partenerNume.Length > 0 ? partenerNume.Substring(0, 1) : "U")
                            </div>
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="mb-1 fw-bold text-truncate">@partenerNume</h6>
                                <small class="text-muted d-block text-truncate">
                                    @if (conv.Anunturi != null)
                                    {
                                        <span>Ref: @conv.Anunturi.Denumire</span>
                                    }
                                    else
                                    {
                                        <span>Discuție generală</span>
                                    }
                                </small>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>

        <div class="chat-main">
            @if (activeChat != null)
            {
                var partenerMain = (activeChat.ID_Utilizator_client == currentUserId)
                ? activeChat.Utilizator_proprietar
                : activeChat.Utilizator_client;
                string partenerMainNume = partenerMain != null ? $"{partenerMain.Nume} {partenerMain.Prenume}" : "Utilizator";

                <div class="chat-header">
                    <div>
                        <h5 class="m-0 fw-bold">@partenerMainNume</h5>
                        @if (activeChat.Anunturi != null)
                        {
                            <small class="text-muted">Interesat de: <a href="/Anunturi/Details/@activeChat.ID_Anunt" target="_blank">@activeChat.Anunturi.Denumire</a></small>
                        }
                    </div>
                </div>

                <div class="messages-container" id="chatBox">
                    @if (activeChat.ListaMesaje != null && activeChat.ListaMesaje.Any())
                    {
                        // Ordonam mesajele cronologic: Data + Ora
                        var mesajeOrdonate = activeChat.ListaMesaje
                        .OrderBy(m => m.Data)
                        .ThenBy(m => m.Ora)
                        .ToList();

                        foreach (var msg in mesajeOrdonate)
                        {
                            bool isMe = msg.ID_Utilizator_expeditor == currentUserId;

                            <div class="msg-bubble fade-in @(isMe ? "msg-me" : "msg-them")">
                                @msg.Text
                                <span class="msg-time">
                                    @msg.Data.ToString("dd MMM") @msg.Ora.ToString("HH:mm")
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted mt-5">
                            <i class="bi bi-chat-dots fs-1"></i>
                            <p>Începe conversația!</p>
                        </div>
                    }
                </div>

                <div class="chat-footer">
                    <form asp-action="TrimiteMesaj" method="post" class="d-flex gap-2">
                        <input type="hidden" name="idConversatie" value="@activeChat.ID_Conversatie" />

                        <input type="text" name="textMesaj" class="form-control rounded-pill border bg-light px-3"
                               placeholder="Scrie un mesaj..." required autocomplete="off" />

                        <button type="submit" class="btn btn-primary rounded-circle" style="width: 45px; height: 45px;">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="d-flex flex-column justify-content-center align-items-center h-100 bg-light text-muted">
                    <i class="bi bi-chat-square-text display-3 mb-3 opacity-25"></i>
                    <h4>Mesagerie Imobiliară</h4>
                    <p>Selectează o conversație din stânga pentru a citi mesajele.</p>
                </div>
            }
        </div>
    </div>
</div>
</div>
@section Scripts {
    <script>
        // Scroll automat la ultimul mesaj
        var chatBox = document.getElementById("chatBox");
        if (chatBox) {
            chatBox.scrollTop = chatBox.scrollHeight;
        }
    </script>
}