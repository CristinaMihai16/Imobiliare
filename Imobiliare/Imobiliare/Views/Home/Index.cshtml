@model IEnumerable<Imobiliare.Models.Anunturi>

@{
    ViewData["Title"] = "Platformă Imobiliară";
    Layout = "_Layout";
}

<style>
    /* ── HERO ── */
    .hero-modern {
        position: relative;
        min-height: 92vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
        margin-top: 56px;
        background: linear-gradient(135deg, #1a0a2e 0%, #2d1048 40%, #0d2a3a 100%);
    }

        /* particule decorative fundal */
        .hero-modern::before {
            content: "";
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(195,63,195,0.18) 0%, transparent 70%);
            top: -150px;
            left: -100px;
            pointer-events: none;
        }

        .hero-modern::after {
            content: "";
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(117,197,203,0.16) 0%, transparent 70%);
            bottom: -120px;
            right: -80px;
            pointer-events: none;
        }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 0 16px;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 30px;
        padding: 7px 18px;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: #75c5cb;
        margin-bottom: 28px;
    }

        .hero-eyebrow::before {
            content: "";
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #75c5cb;
            box-shadow: 0 0 0 3px rgba(117,197,203,0.25);
            animation: pulse-dot 2s infinite;
        }

    @@keyframes pulse-dot {
        0%, 100% {
            box-shadow: 0 0 0 3px rgba(117,197,203,0.25);
        }

        50% {
            box-shadow: 0 0 0 7px rgba(117,197,203,0.08);
        }
    }

    .hero-title {
        font-size: clamp(2.4rem, 6vw, 4.2rem);
        font-weight: 900;
        line-height: 1.1;
        color: white;
        margin-bottom: 18px;
        letter-spacing: -1.5px;
    }

        .hero-title .accent {
            background: linear-gradient(135deg, #75c5cb, #C33FC3);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .hero-subtitle {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.55);
        margin-bottom: 48px;
        font-weight: 400;
        max-width: 480px;
        margin-left: auto;
        margin-right: auto;
    }

    /* ── SEARCH FORM ── */
    .search-glass {
        background: rgba(255,255,255,0.07);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 22px;
        padding: 20px 24px;
        max-width: 860px;
        margin: 0 auto;
    }

        .search-glass .form-control,
        .search-glass .form-select {
            background: rgba(255,255,255,0.10) !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
            border-radius: 14px !important;
            color: white !important;
            padding: 14px 18px !important;
            font-size: 0.95rem !important;
            transition: border-color 0.2s ease, background 0.2s ease;
        }

            .search-glass .form-control::placeholder {
                color: rgba(255,255,255,0.45) !important;
            }

            .search-glass .form-select option {
                background: #2d1048;
                color: white;
            }

            .search-glass .form-control:focus,
            .search-glass .form-select:focus {
                background: rgba(255,255,255,0.16) !important;
                border-color: rgba(117,197,203,0.6) !important;
                box-shadow: 0 0 0 3px rgba(117,197,203,0.15) !important;
                color: white !important;
            }

    .btn-search-hero {
        background: linear-gradient(135deg, #C33FC3, #a530a5);
        border: none;
        border-radius: 14px !important;
        padding: 14px !important;
        font-weight: 700;
        font-size: 0.95rem;
        color: white !important;
        width: 100%;
        transition: all 0.25s ease;
        box-shadow: 0 6px 20px rgba(195,63,195,0.35);
    }

        .btn-search-hero:hover {
            background: linear-gradient(135deg, #75c5cb, #52b0b7);
            box-shadow: 0 8px 24px rgba(117,197,203,0.4);
            transform: translateY(-1px);
            color: white !important;
        }

    /* stats sotto hero */
    .hero-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-top: 44px;
        flex-wrap: wrap;
    }

    .hero-stat {
        text-align: center;
    }

    .hero-stat-num {
        font-size: 1.7rem;
        font-weight: 800;
        color: white;
        display: block;
        line-height: 1;
    }

    .hero-stat-label {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.45);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-top: 4px;
    }

    .hero-stat-divider {
        width: 1px;
        height: 40px;
        background: rgba(255,255,255,0.1);
        align-self: center;
    }

    /* scroll indicator */
    .scroll-hint {
        position: absolute;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,0.3);
        font-size: 0.72rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        animation: bounce-scroll 2s infinite;
    }

    @@keyframes bounce-scroll {
        0%, 100% {
            transform: translateX(-50%) translateY(0);
        }

        50% {
            transform: translateX(-50%) translateY(6px);
        }
    }

    /* ── SEZIONE ANUNTURI ── */
    .anunturi-section {
        background: linear-gradient(180deg, #f5eeff 0%, #edf8f9 100%);
        padding: 80px 0 90px;
    }

    .section-header {
        text-align: center;
        margin-bottom: 52px;
    }

    .section-tag {
        display: inline-block;
        background: linear-gradient(135deg, rgba(117,197,203,0.15), rgba(195,63,195,0.12));
        border: 1px solid rgba(117,197,203,0.3);
        border-radius: 20px;
        padding: 5px 16px;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #3a9aa2;
        margin-bottom: 14px;
    }

    .section-title-main {
        font-size: 2.2rem;
        font-weight: 800;
        color: #1a0a2e;
        letter-spacing: -0.5px;
        margin: 0 0 10px;
    }

        .section-title-main span {
            background: linear-gradient(135deg, #75c5cb, #C33FC3);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .section-desc {
        color: #8a6b9a;
        font-size: 1rem;
        max-width: 420px;
        margin: 0 auto;
    }

    /* Cards */
    .anunt-card {
        background: white;
        border-radius: 22px;
        border: 1px solid rgba(195,63,195,0.08);
        overflow: hidden;
        box-shadow: 0 6px 28px rgba(100,50,120,0.08);
        transition: transform 0.32s cubic-bezier(.22,.68,0,1.2), box-shadow 0.32s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .anunt-card:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: 0 20px 50px rgba(195,63,195,0.16);
        }

    .card-img-wrap {
        position: relative;
        overflow: hidden;
    }

        .card-img-wrap img {
            width: 100%;
            height: 230px;
            object-fit: cover;
            display: block;
            transition: transform 0.5s ease;
        }

    .anunt-card:hover .card-img-wrap img {
        transform: scale(1.07);
    }

    .card-img-wrap::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(26,10,46,0.5) 0%, transparent 55%);
        pointer-events: none;
    }

    .price-badge {
        position: absolute;
        bottom: 14px;
        left: 14px;
        z-index: 2;
        background: rgba(255,255,255,0.96);
        color: #1a0a2e;
        font-weight: 800;
        font-size: 1rem;
        padding: 6px 16px;
        border-radius: 30px;
        box-shadow: 0 4px 14px rgba(0,0,0,0.15);
    }

    .favorite-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
        background: rgba(255,255,255,0.18) !important;
        border: none !important;
        width: 40px;
        height: 40px;
        border-radius: 50% !important;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        transition: background 0.2s, transform 0.2s;
        padding: 0 !important;
    }

        .favorite-btn:hover {
            background: rgba(255,255,255,0.38) !important;
            transform: scale(1.12);
        }

        .favorite-btn i {
            font-size: 1.2rem;
            display: inline-block;
        }

    .card-content {
        padding: 20px 22px 24px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .card-anunt-title {
        font-size: 1.02rem;
        font-weight: 700;
        color: #1a0a2e;
        margin-bottom: 6px;
        line-height: 1.3;
    }

    .card-location {
        font-size: 0.87rem;
        color: #9a7aaa;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .card-location i {
            color: #C33FC3;
        }

    .btn-detalii {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: linear-gradient(135deg, #75c5cb, #52b0b7);
        color: white !important;
        border: none;
        border-radius: 12px;
        padding: 11px 18px;
        font-size: 0.91rem;
        font-weight: 600;
        text-decoration: none;
        margin-top: auto;
        transition: all 0.25s ease;
    }

        .btn-detalii:hover {
            background: linear-gradient(135deg, #C33FC3, #a530a5);
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(195,63,195,0.28);
            color: white !important;
        }

    /* CTA bottom */
    .cta-wrap {
        text-align: center;
        margin-top: 56px;
    }

    .btn-exploreaza {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: transparent;
        border: 2px solid #C33FC3;
        color: #C33FC3 !important;
        border-radius: 50px;
        padding: 14px 36px;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.28s ease;
    }

        .btn-exploreaza:hover {
            background: linear-gradient(135deg, #C33FC3, #a530a5);
            border-color: transparent;
            color: white !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(195,63,195,0.3);
        }

    /* animatie inima */
    .heart-animate {
        animation: heartPop 0.35s ease;
    }

    @@keyframes heartPop {
        0% {
            transform: scale(1);
        }

        35% {
            transform: scale(1.5);
            filter: drop-shadow(0 0 8px rgba(255,0,0,0.5));
        }

        55% {
            transform: scale(0.85);
        }

        100% {
            transform: scale(1);
        }
    }

    @@media (max-width: 768px) {
        .hero-title {
            letter-spacing: -0.8px;
        }

        .hero-stats {
            gap: 24px;
        }

        .hero-stat-divider {
            display: none;
        }
    }
</style>

<main>
    @Html.AntiForgeryToken()

    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="hero-modern">
        <div class="hero-content container">

            <div class="hero-eyebrow">Platformă Imobiliară</div>

            <h1 class="hero-title">
                Găsește-ți<br>
                <span class="accent">casa visată</span>
            </h1>

            <p class="hero-subtitle">
                Descoperă proprietăți unice, fără compromisuri.
            </p>

            <!-- Search form -->
            <form asp-controller="Home" asp-action="Search" method="get" class="search-glass">
                <div class="row g-3 align-items-center">
                    <div class="col-md-5">
                        <input type="text" name="oras"
                               class="form-control"
                               placeholder="Oraș sau zonă...">
                    </div>
                    <div class="col-md-3">
                        <select name="tranzactie" class="form-select">
                            <option value="">Tranzacție</option>
                            <option value="Vanzare">Vânzare</option>
                            <option value="Inchiriere">Închiriere</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="tip" class="form-select">
                            <option value="">Proprietate</option>
                            <option value="Apartament">Apartament</option>
                            <option value="Garsoniera">Garsonieră</option>
                            <option value="Casa">Casă/Vilă</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn-search-hero">
                            <i class="bi bi-search"></i> Caută
                        </button>
                    </div>
                </div>
            </form>

            <!-- Stats -->
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-num">500+</span>
                    <span class="hero-stat-label">Proprietăți</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">120+</span>
                    <span class="hero-stat-label">Orașe</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">2.4k</span>
                    <span class="hero-stat-label">Utilizatori</span>
                </div>
            </div>

        </div>

        <div class="scroll-hint">
            <i class="bi bi-chevron-down"></i>
            Scroll
        </div>
    </section>

    <!-- ═══════════════════ ANUNTURI RECENTE ═══════════════════ -->
    <section class="anunturi-section">
        <div class="container">

            <div class="section-header">
                <div class="section-tag">Cele mai noi</div>
                <h2 class="section-title-main">Anunțuri <span>recente</span></h2>
                <p class="section-desc">Proprietăți proaspăt adăugate, direct de la proprietari</p>
            </div>

            <div class="row g-4">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        var favList = ViewBag.FavoriteIds as List<int?>;
                        bool isFav = favList != null && favList.Contains(item.ID_Anunt);

                        <div class="col-sm-12 col-md-6 col-lg-4">
                            <div class="anunt-card">
                                <div class="card-img-wrap">
                                    @{
                                        string imgSrc = item.Imagine_anunt != null && item.Imagine_anunt.Length > 0
                                        ? $"data:image/jpeg;base64,{Convert.ToBase64String(item.Imagine_anunt)}"
                                        : "https://via.placeholder.com/400x300?text=Fara+Imagine";
                                    }
                                    <img src="@imgSrc" alt="@item.Denumire">

                                    <span class="price-badge">@item.Pret.ToString("N0") €</span>

                                    <button class="favorite-btn"
                                            data-id="@item.ID_Anunt"
                                            data-favorite="@(isFav.ToString().ToLower())">
                                        <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart text-white")"></i>
                                    </button>
                                </div>

                                <div class="card-content">
                                    <h5 class="card-anunt-title">@item.Denumire</h5>
                                    <p class="card-location">
                                        <i class="bi bi-geo-alt-fill"></i> @item.Oras
                                    </p>
                                    <a asp-controller="Anunturi" asp-action="Details" asp-route-id="@item.ID_Anunt"
                                       class="btn-detalii">
                                        Vezi Detalii <i class="bi bi-arrow-right-short" style="font-size:1.1rem;"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <p style="color:#9a7aaa;">Nu există anunțuri recente momentan.</p>
                    </div>
                }
            </div>

            <div class="cta-wrap">
                <a asp-controller="Anunturi" asp-action="Index" class="btn-exploreaza">
                    Explorează toate anunțurile <i class="bi bi-arrow-right"></i>
                </a>
            </div>

        </div>
    </section>
</main>

@section Scripts {
    <script>
        document.querySelectorAll(".favorite-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                const anuntId = this.dataset.id;
                const isFav = this.dataset.favorite === "true";
                const icon = this.querySelector("i");
                const token = document.querySelector("input[name='__RequestVerificationToken']").value;

                fetch('/Favorite/ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `anuntId=${anuntId}&action=${isFav ? "remove" : "add"}`
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        icon.classList.add("heart-animate");
                        setTimeout(() => icon.classList.remove("heart-animate"), 350);
                        if (isFav) {
                            icon.classList.remove("bi-heart-fill", "text-danger");
                            icon.classList.add("bi-heart", "text-white");
                            this.dataset.favorite = "false";
                        } else {
                            icon.classList.remove("bi-heart", "text-white");
                            icon.classList.add("bi-heart-fill", "text-danger");
                            this.dataset.favorite = "true";
                        }
                    }
                });
            });
        });
    </script>
}
