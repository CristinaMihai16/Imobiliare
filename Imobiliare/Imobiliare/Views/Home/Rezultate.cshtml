@model List<Imobiliare.Models.Anunturi>

@{
    ViewData["Title"] = "Rezultate Căutare";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/add.css" />

<div class="container py-5 fade-in">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary-modern">
            <i class="bi bi-search"></i> Rezultate Căutare
        </h2>
        <a asp-controller="Anunturi" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-counterclockwise"></i> Resetează Filtrele
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-emoji-frown display-1 text-muted"></i>
            </div>
            <h3 class="fw-bold text-secondary">Nu am găsit proprietăți...</h3>
            <p class="text-muted">Încearcă să modifici criteriile de căutare.</p>

            <a asp-controller="Anunturi" asp-action="Index" class="btn btn-primary px-4 mt-3 rounded-pill">
                Vezi toate anunțurile
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden hover-effect">

                        <div class="position-relative">
                            @{
                                string imgSrc = "https://via.placeholder.com/600x400?text=Fara+Imagine";
                                if (item.Imagine_anunt != null && item.Imagine_anunt.Length > 0)
                                {
                                    var base64 = Convert.ToBase64String(item.Imagine_anunt);
                                    imgSrc = $"data:image/jpeg;base64,{base64}";
                                }
                            }

                            <img src="@imgSrc" class="card-img-top" style="height: 220px; object-fit: cover;" alt="@item.Denumire">

                            @{
                                var badgeClass = item.Tranzactie == "Inchiriere" ? "bg-warning text-dark" : "bg-success";
                            }
                            <span class="badge @badgeClass position-absolute top-0 start-0 m-3 shadow-sm px-3 py-2 rounded-pill">
                                @item.Tranzactie
                            </span>

                            <div class="position-absolute bottom-0 end-0 m-3">
                                <span class="badge bg-white text-dark shadow fw-bold fs-6 py-2 px-3 rounded-pill">
                                    @item.Pret.ToString("N0") €
                                </span>
                            </div>
                        </div>

                        <div class="card-body p-4 d-flex flex-column">

                            <h5 class="card-title fw-bold text-truncate" title="@item.Denumire">
                                @item.Denumire
                            </h5>

                            <div class="mb-3 text-muted small">
                                <i class="bi bi-geo-alt-fill text-danger"></i> @item.Oras
                                <span class="mx-1">•</span>
                                <i class="bi bi-building"></i> @item.TipProprietate
                            </div>

                            <div class="mt-auto">
                                <a asp-controller="Anunturi" asp-action="Details" asp-route-id="@item.ID_Anunt"
                                   class="btn btn-outline-primary w-100 rounded-pill fw-bold">
                                    Vezi Detalii <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Mic efect de hover pentru carduri */
    .hover-effect {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-effect:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>