@using System.Security.Claims
@model IEnumerable<Imobiliare.Models.Anunturi>

<main class="container py-5">

    <h2 class="text-center mb-5 text-section-title fw-bold">
        Toate Anunțurile
    </h2>

    <div class="row justify-content-center">

        @if (Model != null && Model.Any())
        {
            var favList = ViewBag.FavoriteIds as List<int?>;

            // 1. Preluăm ID-ul utilizatorului logat
            var currentUserIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
            int currentUserId = 0;
            int.TryParse(currentUserIdStr, out currentUserId);

            foreach (var item in Model)
            {
                bool isFav = favList != null && favList.Contains(item.ID_Anunt);

                // 1. Identificare user și roluri
                bool isAdmin = User.IsInRole("Administrator"); // Verificăm dacă e Admin
                bool isOwner = User.Identity.IsAuthenticated && (currentUserId == item.ID_Utilizator); // Verificăm dacă e Proprietar

                // 2. Stabilirea permisiunilor EXACT cum ai cerut
                // Editare: DOAR dacă ești proprietarul anunțului (Adminul nu editează textele altora)
                bool canEdit = isOwner;

                // Ștergere: Dacă ești proprietar SAU dacă ești Admin (ca să poți modera)
                bool canDelete = isOwner || isAdmin;

                <div class="col-sm-12 col-md-6 col-lg-4 mb-5">

                    <div class="card h-100 shadow-lg border-0 rounded-4 card-modern overflow-hidden">

                        <div class="position-relative">
                            @{
                                string imgSrc = item.Imagine_anunt != null && item.Imagine_anunt.Length > 0
                                ? $"data:image/jpeg;base64,{Convert.ToBase64String(item.Imagine_anunt)}"
                                : "https://via.placeholder.com/400x300?text=Fara+Imagine";
                            }

                            <img src="@imgSrc"
                                 class="card-img-top"
                                 style="height: 250px; width: 100%; object-fit: cover;"
                                 alt="@item.Denumire" />

                            <span class="badge bg-dark position-absolute bottom-0 start-0 m-3 fs-5 p-2">
                                @item.Pret.ToString("N0") €
                            </span>

                            <button class="favorite-btn btn btn-sm position-absolute top-0 end-0 m-3"
                                    data-id="@item.ID_Anunt"
                                    data-favorite="@isFav.ToString().ToLower()"
                                    style="background: none; border: none;">
                                <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart text-white") fs-2"></i>
                            </button>
                        </div>

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title fw-bold">@item.Denumire</h5>

                            <p class="card-text text-muted mb-3">
                                <i class="bi bi-geo-alt-fill"></i> @item.Oras
                            </p>

                            <a asp-controller="Anunturi"
                               asp-action="Details"
                               asp-route-id="@item.ID_Anunt"
                               class="btn btn-primary-modern mt-auto">
                                Vezi Detalii <i class="bi bi-arrow-right"></i>
                            </a>

                            <div class="d-flex justify-content-between mt-4 border-top pt-3">

                                @if (canEdit)
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.ID_Anunt"
                                       class="btn btn-sm btn-outline-secondary px-3">
                                        <i class="bi bi-pencil"></i> Editare
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary px-3 invisible" disabled tabindex="-1">Editare</button>
                                }

                                @if (canDelete)
                                {
                                    <a asp-action="Delete"
                                       asp-route-id="@item.ID_Anunt"
                                       class="btn btn-sm btn-outline-danger px-3">
                                        <i class="bi bi-trash"></i> Ștergere
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger px-3 invisible" disabled tabindex="-1">Ștergere</button>
                                }

                            </div>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p class="text-muted">Nu există anunțuri momentan.</p>
                <a asp-action="Create" class="btn btn-success">Adaugă un anunț nou</a>
            </div>
        }

    </div>

</main>