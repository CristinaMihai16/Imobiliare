@model IEnumerable<Imobiliare.Models.Anunturi>

@{
    ViewData["Title"] = "Toate Anunțurile";
}

<h2 class="text-center mb-5 text-section-title fw-bold">Toate Anunțurile</h2>

<div class="row">
    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col-sm-12 col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-lg border-0 rounded-4 card-modern overflow-hidden">
                    <div class="card-img-top-container position-relative">

                        @{
                            // Logica pentru afisarea imaginii din baza de date (byte[])
                            string imgSrc = "";
                            if (item.Imagine_anunt != null && item.Imagine_anunt.Length > 0)
                            {
                                var base64 = Convert.ToBase64String(item.Imagine_anunt);
                                imgSrc = String.Format("data:image/jpg;base64,{0}", base64);
                            }
                            else
                            {
                                // Imagine default daca nu exista
                                imgSrc = "https://via.placeholder.com/400x300?text=Fara+Imagine";
                            }
                        }

                        <img src="@imgSrc" class="card-img-top" alt="@item.Denumire" style="height: 250px; object-fit: cover; width: 100%;">

                        <span class="badge bg-dark position-absolute bottom-0 start-0 m-3 fs-5 p-2">
                            @item.Pret.ToString("N0") €
                        </span>

                        <button class="btn btn-sm position-absolute top-0 end-0 m-3 btn-favorite-modern">
                            <i class="bi bi-heart"></i>
                        </button>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@item.Denumire</h5>
                        <p class="card-text text-muted mb-3">
                            <i class="bi bi-geo-alt-fill"></i> @item.Locatie
                        </p>

                        <a asp-controller="Anunturi" asp-action="Details" asp-route-id="@item.ID_Anunt" class="btn btn-primary-modern mt-auto">
                            Vezi Detalii <i class="bi bi-arrow-right"></i>
                        </a>

                        @* Adaugă aici link-urile de Edit/Delete dacă sunt necesare *@
                        <div class="d-flex justify-content-end mt-2">
                            <a asp-action="Edit" asp-route-id="@item.ID_Anunt" class="btn btn-sm btn-outline-secondary me-2">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.ID_Anunt" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center">
            <p class="text-muted">Momentan nu sunt publicate anunțuri.</p>
            <p><a asp-action="Create" class="btn btn-success">Adaugă un anunț nou</a></p>
        </div>
    }
</div>