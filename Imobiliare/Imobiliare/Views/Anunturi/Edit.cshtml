@model Imobiliare.Models.Anunturi

@{
    ViewData["Title"] = $"Editează Anunțul: {Model.Denumire}";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/add.css" />

<main class="add-wrapper py-5">

    <div class="container fade-in mb-4">
        @if (TempData["eroare"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                <strong>⚠️ Eroare!</strong> @TempData["eroare"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["succes"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <strong>✨ Succes!</strong> @TempData["succes"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <div class="text-center mb-5 fade-in">
        <h1 class="add-title fw-bold">✨ Editează anunțul ✨</h1>
    </div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="add-card shadow-lg fade-in">

                    <form asp-action="Edit" method="post" enctype="multipart/form-data">

                        <input type="hidden" asp-for="ID_Anunt" />
                        <input type="hidden" asp-for="Data_publicare" />
                        <input type="hidden" asp-for="ID_Utilizator" />

                        <h4 class="section-title mt-3">Detalii principale</h4>

                        <div class="mb-4">
                            <label asp-for="Denumire" class="form-label fw-semibold">Titlu Anunț</label>
                            <input asp-for="Denumire" class="form-control add-input" />
                            <span asp-validation-for="Denumire" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Descriere" class="form-label fw-semibold">Descriere</label>
                            <textarea asp-for="Descriere" class="form-control add-input" rows="5"></textarea>
                            <span asp-validation-for="Descriere" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-4">
                                <label asp-for="Pret" class="form-label fw-semibold">Preț (EUR)</label>
                                <input asp-for="Pret" type="number" class="form-control add-input" />
                                <span asp-validation-for="Pret" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-4">
                                <label asp-for="Oras" class="form-label fw-semibold">Oraș</label>
                                <input asp-for="Oras" class="form-control add-input" />
                                <span asp-validation-for="Oras" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-4">
                                <label asp-for="Locatie" class="form-label fw-semibold">Locație</label>
                                <input asp-for="Locatie" class="form-control add-input" placeholder="Strada..." />
                                <span asp-validation-for="Locatie" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Tranzactie" class="form-label fw-semibold">Tranzacție</label>
                                <select asp-for="Tranzactie" class="form-select add-input">
                                    <option value="Vanzare">Vânzare</option>
                                    <option value="Inchiriere">Închiriere</option>
                                </select>
                                <span asp-validation-for="Tranzactie" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="TipProprietate" class="form-label fw-semibold">Tip Proprietate</label>
                                <select asp-for="TipProprietate" class="form-select add-input">
                                    <option value="Apartament">Apartament</option>
                                    <option value="Garsoniera">Garsonieră</option>
                                    <option value="Casa">Casă / Vilă</option>
                                    <option value="Teren">Teren</option>
                                    <option value="SpatiuComercial">Spațiu Comercial</option>
                                </select>
                                <span asp-validation-for="TipProprietate" class="text-danger small"></span>
                            </div>
                        </div>

                        <h4 class="section-title mt-4">Imaginea de copertă</h4>
                        <div class="mb-4 p-3 border rounded-4 bg-white bg-opacity-75">
                            <div class="row align-items-center">
                                <div class="col-md-4 text-center">
                                    @if (Model.Imagine_anunt != null && Model.Imagine_anunt.Length > 0)
                                    {
                                        var base64 = Convert.ToBase64String(Model.Imagine_anunt);
                                        <img src="data:image/jpeg;base64,@base64" class="img-fluid rounded shadow-sm" style="max-height: 100px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Fără copertă</span>
                                    }
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label small text-muted">Schimbă coperta (înlocuiește imaginea veche)</label>
                                    <input type="file" name="ImagineFile" class="form-control" accept="image/*" />
                                </div>
                            </div>
                        </div>


                        <h4 class="section-title mt-4">Galerie Foto</h4>

                        <div class="mb-4 p-3 border rounded-4 bg-light">
                            <label class="form-label fw-bold mb-3">Imagini existente în galerie:</label>

                            @if (Model.Imagini != null && Model.Imagini.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var img in Model.Imagini)
                                    {
                                        var base64 = Convert.ToBase64String(img.Imagine);
                                        <div class="col-6 col-md-4 col-lg-3 text-center">
                                            <div class="card h-100 shadow-sm border-0 position-relative">
                                                <img src="data:image/jpeg;base64,@base64" class="card-img-top" style="height: 100px; object-fit: cover; border-radius: 8px 8px 0 0;" />

                                                <button type="submit"
                                                        class="btn btn-danger btn-sm w-100 rounded-0 rounded-bottom"
                                                        asp-action="StergeImagine"
                                                        asp-route-id="@img.ID_ImaginiAnunt"
                                                        formnovalidate="formnovalidate"
                                                        onclick="return confirm('Ești sigur că vrei să ștergi această imagine?');">
                                                    <i class="bi bi-trash"></i> Șterge
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted fst-italic p-2 bg-white rounded border">Nu există alte imagini în galerie.</p>
                            }

                            <hr class="my-4" />

                            <label class="form-label fw-bold text-success">
                                <i class="bi bi-plus-circle-fill"></i> Adaugă imagini noi
                            </label>

                            <input type="file" name="ImaginiNoi" multiple class="form-control add-input" accept="image/*" />
                            <div class="form-text text-muted">
                                Poți selecta mai multe imagini simultan (CTRL + Click). Se vor <strong>adăuga</strong> la cele existente.
                            </div>
                        </div>

                        <div class="text-center mt-5">
                            <button type="submit" class="add-btn fw-bold px-5 py-2">
                                <i class="bi bi-floppy-fill"></i> Salvează Modificările
                            </button>
                        </div>

                    </form>
                </div>

                <div class="text-center mt-4 fade-in">
                    <a asp-action="Index" class="back-link text-decoration-none">
                        <i class="bi bi-arrow-left-circle"></i> Înapoi la listă
                    </a>
                </div>

            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}