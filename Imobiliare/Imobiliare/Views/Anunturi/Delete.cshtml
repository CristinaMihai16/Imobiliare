@model Imobiliare.Models.Anunturi

@{
    ViewData["Title"] = $"Șterge: {Model.Denumire}";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/add.css" />

<div class="delete-wrapper py-5 fade-in">

    <div class="container">

        <div class="card shadow-lg border-0 rounded-4 p-5 mb-5 delete-warning-card">
            <div class="text-center">
                <h1 class="display-6 fw-bold text-danger mb-3">
                    ⚠️ Ștergere definitivă
                </h1>
                <p class="lead text-muted">
                    Ești sigur că vrei să ștergi anunțul <strong>"@Model.Denumire"</strong>?
                    <br />
                    Toate datele, inclusiv <strong>imaginile din galerie</strong> și conversațiile asociate, vor fi pierdute ireversibil.
                </p>
            </div>
        </div>

        <div class="card shadow-lg border-0 rounded-4 p-4 delete-details-card">

            <div class="row">
                <div class="col-md-5 text-center mb-4 mb-md-0">
                    @{
                        string imgSrc = "";
                        if (Model.Imagine_anunt != null && Model.Imagine_anunt.Length > 0)
                        {
                            var base64 = Convert.ToBase64String(Model.Imagine_anunt);
                            imgSrc = $"data:image/jpeg;base64,{base64}";
                        }
                        else
                        {
                            imgSrc = "https://via.placeholder.com/600x400?text=Fara+Imagine";
                        }
                    }

                    <img src="@imgSrc"
                         class="rounded-4 shadow-sm img-fluid"
                         alt="@Model.Denumire"
                         style="max-height: 300px; object-fit: cover;">

                    @if (Model.Imagini != null && Model.Imagini.Count > 0)
                    {
                        <div class="mt-3 text-danger small fw-bold">
                            <i class="bi bi-images"></i> Acest anunț mai conține @Model.Imagini.Count imagini în galerie care vor fi șterse.
                        </div>
                    }
                </div>

                <div class="col-md-7">
                    <h4 class="mb-4 text-secondary border-bottom pb-2">Detalii Proprietate</h4>

                    <dl class="row mb-0 align-items-center">

                        <dt class="col-sm-4 fw-bold text-secondary">Titlu:</dt>
                        <dd class="col-sm-8 fw-bold text-dark">@Model.Denumire</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Preț:</dt>
                        <dd class="col-sm-8 text-success fw-bold fs-5">@Model.Pret.ToString("N0") €</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Oraș:</dt>
                        <dd class="col-sm-8">@Model.Oras</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Adresă:</dt>
                        <dd class="col-sm-8">@Model.Locatie</dd>

                        <hr class="my-2 text-muted opacity-25" />

                        <dt class="col-sm-4 fw-bold text-secondary">Tip:</dt>
                        <dd class="col-sm-8">@Model.TipProprietate</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Tranzacție:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-primary rounded-pill px-3">@Model.Tranzactie</span>
                        </dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Publicat pe:</dt>
                        <dd class="col-sm-8">@Model.Data_publicare.ToShortDateString()</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Proprietar:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Utilizator != null)
                            {
                                <span>@Model.Utilizator.Nume @Model.Utilizator.Prenume</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </dd>
                    </dl>

                    <div class="mt-3 p-3 bg-light rounded-3 border">
                        <small class="text-muted fw-bold">Descriere:</small>
                        <p class="mb-0 small text-secondary fst-italic text-truncate" style="max-height: 60px;">
                            @Model.Descriere
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <div class="text-center mt-5">
            <form asp-action="Delete">
                <input type="hidden" asp-for="ID_Anunt" />

                <button type="submit" class="btn btn-danger btn-lg px-5 py-2 fw-bold me-3 shadow-sm rounded-pill">
                    <i class="bi bi-trash-fill"></i> Confirmă Ștergerea
                </button>

                <a asp-action="Index" class="btn btn-light btn-lg px-4 py-2 fw-bold shadow-sm rounded-pill border">
                    <i class="bi bi-x-circle"></i> Anulează
                </a>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}