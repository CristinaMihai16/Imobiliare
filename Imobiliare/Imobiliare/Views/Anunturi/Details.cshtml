@using System.Security.Claims
@model Imobiliare.Models.Anunturi

@{
    ViewData["Title"] = Model.Denumire;
    Layout = "_Layout";

    // --- LOGICA DE PERMISIUNI ---
    bool isOwner = false;
    bool isAdmin = false;

    if (User.Identity.IsAuthenticated)
    {
        var userIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
        int currentUserId = 0;

        if (int.TryParse(userIdString, out currentUserId))
        {
            // Verificăm dacă este proprietar
            if (currentUserId == Model.ID_Utilizator)
            {
                isOwner = true;
            }
        }

        // Verificăm dacă este administrator
        isAdmin = User.IsInRole("Administrator");
    }

    // Reguli finale
    bool canEdit = isOwner;              // Doar proprietarul poate edita
    bool canDelete = isOwner || isAdmin; // Proprietarul sau Adminul pot șterge
    // ----------------------------
}

<link rel="stylesheet" href="~/css/add.css" />

<div class="details-wrapper py-5">

    <div class="container fade-in">

        <div class="row mb-4 align-items-center">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold details-title">@Model.Denumire</h1>
                <p class="lead text-muted">
                    <i class="bi bi-geo-alt-fill text-primary-modern"></i> @Model.Oras
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <div class="price-box shadow-sm">
                    <span>@Model.Pret.ToString("N0") €</span>
                </div>
            </div>
        </div>

        <div class="row">

            <div class="col-lg-8">

                <div class="card details-card shadow-lg border-0 rounded-4 mb-4">
                    @if (Model.Imagini != null && Model.Imagini.Any())
                    {
                        <div id="carouselAnunt" class="carousel slide rounded-4 overflow-hidden shadow mb-4" data-bs-ride="carousel">
                            <div class="carousel-inner">
                                @for (int i = 0; i < Model.Imagini.Count(); i++)
                                {
                                    var imgBytes = Model.Imagini.ElementAt(i).Imagine;
                                    var base64 = Convert.ToBase64String(imgBytes);
                                    var imgsrc = $"data:image/jpeg;base64,{base64}";

                                    <div class="carousel-item @(i == 0 ? "active" : "")">
                                        <img src="@imgsrc" class="d-block w-100" style="max-height: 550px; object-fit: cover;" />
                                    </div>
                                }
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#carouselAnunt" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon"></span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carouselAnunt" data-bs-slide="next">
                                <span class="carousel-control-next-icon"></span>
                            </button>
                            <div class="carousel-indicators">
                                @for (int i = 0; i < Model.Imagini.Count(); i++)
                                {
                                    <button type="button" data-bs-target="#carouselAnunt" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        string imgSrc = (Model.Imagine_anunt != null && Model.Imagine_anunt.Length > 0)
                        ? $"data:image/jpeg;base64,{Convert.ToBase64String(Model.Imagine_anunt)}"
                        : "https://via.placeholder.com/800x600?text=Fara+Imagine";
                        <img src="@imgSrc" class="d-block w-100 rounded-4 mb-3" style="max-height: 550px; object-fit: cover;" />
                    }
                </div>

                <div class="card-body p-4">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-3 details-section-title">Descrierea proprietății</h4>
                        <p class="details-description">@Model.Descriere</p>

                        <ul class="list-group mb-4">
                            <li class="list-group-item d-flex justify-content-between">
                                <span><i class="bi bi-tags-fill text-primary-modern"></i> Tranzacție:</span>
                                <strong>@Model.Tranzactie</strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span><i class="bi bi-house-fill text-primary-modern"></i> Tip proprietate:</span>
                                <strong>@Model.TipProprietate</strong>
                            </li>
                            @if (Model.Oras != null)
                            {
                                <li class="list-group-item d-flex justify-content-between">
                                    <span><i class="bi bi-geo-alt-fill text-primary-modern"></i> Oraș:</span>
                                    <strong>@Model.Oras</strong>
                                </li>
                            }
                            <li class="list-group-item d-flex justify-content-between">
                                <span><i class="bi bi-house-fill text-primary-modern"></i> Locație:</span>
                                <strong>@Model.Locatie</strong>
                            </li>
                        </ul>
                        <hr />
                        <p class="text-muted small fst-italic">
                            Publicat pe: <strong>@Model.Data_publicare.ToShortDateString()</strong>
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 fade-in">

                @if (Model.Utilizator != null)
                {
                    <div class="card contact-card shadow-lg mb-4 rounded-4">
                        <div class="card-header contact-header rounded-top-4">
                            <i class="bi bi-person-fill"></i> Contact Vânzător
                        </div>

                        <div class="card-body text-center">
                            <h5 class="fw-bold mb-3">
                                @Model.Utilizator.Nume @Model.Utilizator.Prenume
                            </h5>

                            @if (User.Identity.IsAuthenticated && !isOwner)
                            {
                                <a asp-controller="Chat" asp-action="StartChat" asp-route-idAnunt="@Model.ID_Anunt"
                                   class="btn btn-primary w-100 mb-2 rounded-pill shadow-sm fw-bold">
                                    <i class="bi bi-chat-dots-fill"></i> Trimite Mesaj
                                </a>
                            }

                            <a href="tel:@Model.Utilizator.Telefon" class="btn contact-btn w-100 mb-2">
                                <i class="bi bi-telephone-fill"></i> Sună: @Model.Utilizator.Telefon
                            </a>

                            <a href="mailto:@Model.Utilizator.Email" class="btn contact-btn-outline w-100">
                                <i class="bi bi-envelope-fill"></i> Trimite Email
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning shadow-sm rounded-4">
                        Detalii vânzător indisponibile.
                    </div>
                }

                <div class="card action-card shadow-lg rounded-4">
                    <div class="card-body p-4 text-center">

                        <h5 class="fw-bold mb-3 details-section-title">Acțiuni</h5>

                        @if (canEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.ID_Anunt"
                               class="btn action-edit w-100 mb-3">
                                <i class="bi bi-pencil-square"></i> Editează Anunțul
                            </a>
                        }

                        @if (canDelete)
                        {
                            <a asp-action="Delete" asp-route-id="@Model.ID_Anunt"
                               class="btn action-delete w-100 mb-3">
                                <i class="bi bi-trash"></i> Șterge Anunțul
                            </a>
                        }

                        <a asp-action="Index" class="btn action-back w-100 mt-3">
                            <i class="bi bi-arrow-left-circle"></i> Înapoi la listă
                        </a>

                    </div>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}