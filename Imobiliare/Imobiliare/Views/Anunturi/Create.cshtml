@model Imobiliare.Models.Anunturi

@{
    ViewData["Title"] = "Adaugă Anunț";
    Layout = "_Layout";
}

<main class="container py-5 mt-4">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary-modern">Adaugă un Anunț Nou</h1>
        <p class="text-muted">Completează câmpurile de mai jos pentru a publica un anunț pe platformă.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4 p-4">
                <div class="card-body">

                    <form asp-action="Create" enctype="multipart/form-data" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Denumire" class="form-label fw-semibold">Titlu Anunț</label>
                            <input asp-for="Denumire" class="form-control form-control-lg" placeholder="Ex: Apartament 2 camere central" />
                            <span asp-validation-for="Denumire" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descriere" class="form-label fw-semibold">Descriere</label>
                            <textarea asp-for="Descriere" class="form-control" rows="5" placeholder="Scrie detaliile complete ale proprietății…"></textarea>
                            <span asp-validation-for="Descriere" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Pret" class="form-label fw-semibold">Preț (EUR)</label>
                                <input asp-for="Pret" class="form-control" placeholder="Ex: 75000" />
                                <span asp-validation-for="Pret" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Locatie" class="form-label fw-semibold">Locație</label>
                                <input asp-for="Locatie" class="form-control" placeholder="Ex: București, Str. Exemplu nr. 10" />
                                <span asp-validation-for="Locatie" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Imagine Anunț</label>
                            <input type="file" name="ImagineFile" class="form-control" />
                        </div>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-search-action-modern px-5 py-2 fw-bold">
                                <i class="bi bi-check-circle-fill"></i> Publică Anunțul
                            </button>
                        </div>

                    </form>

                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none text-secondary-modern">
                    <i class="bi bi-arrow-left"></i> Înapoi la listă
                </a>
            </div>

        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
