@model Imobiliare.Models.Formular
@{
    ViewData["Title"] = "Contactează-ne";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/contact.css" />

<main class="contact-wrapper">

    @if (TempData["succes"] != null)
    {
        <div class="toast success show">@TempData["succes"]</div>
    }
    @if (TempData["eroare"] != null)
    {
        <div class="toast error show">@TempData["eroare"]</div>
    }

    <div class="container">
        <div class="contact-card mx-auto" style="max-width: 650px;">

            <div class="text-center mb-4">
                <i class="bi bi-envelope-heart-fill contact-icon"></i>
                <h1 class="contact-title mt-3">Contactează-ne</h1>
                <p class="contact-subtitle">Suntem aici pentru tine.</p>
            </div>

            <form asp-action="Index" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nume" class="form-label fw-semibold">Nume complet</label>
                    <input asp-for="Nume" class="form-control contact-input" />
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" type="email" class="form-control contact-input" />
                </div>

                <div class="mb-3">
                    <label asp-for="Subiect" class="form-label fw-semibold">Mesajul tău</label>
                    <textarea asp-for="Subiect" rows="5" class="form-control contact-input"></textarea>
                </div>

                <button type="submit" class="contact-btn w-100">Trimite mesaj</button>

            </form>

        </div>
    </div>

</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        setTimeout(() => {
            const t = document.querySelector(".toast");
            if (t) {
                t.classList.remove("show");
                setTimeout(() => t.remove(), 400);
            }
        }, 3500);
    </script>
}
