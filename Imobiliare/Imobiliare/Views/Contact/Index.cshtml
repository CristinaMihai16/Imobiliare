@model Imobiliare.Models.Formular
@{
    ViewData["Title"] = "Contactează-ne";
    Layout = "_Layout";
}

<!-- Tailwind CDN -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- CSS extern -->
<link rel="stylesheet" href="~/css/contact.css" />

<main class="w-full min-h-screen bg-slate-100 py-16 px-6">

    <!-- Mesaje de succes / eroare -->
    @if (TempData["succes"] != null)
    {
        <div class="toast success show">@TempData["succes"]</div>
    }
    @if (TempData["eroare"] != null)
    {
        <div class="toast error show">@TempData["eroare"]</div>
    }

    <div class="max-w-xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-10">

            <!-- Icon + Titlu -->
            <div class="text-center mb-10">
                <svg class="w-20 h-20 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2">
                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>

                <h1 class="text-4xl font-bold text-slate-900">Contactează-ne</h1>
                <p class="text-slate-500 mt-2">
                    Suntem aici să te ajutăm cu orice întrebare despre proprietăți.
                </p>
            </div>

            <!-- FORMULAR -->
            <form asp-action="Index" method="post" id="contactForm">

                <div asp-validation-summary="ModelOnly"
                     class="text-red-600 font-semibold mb-4"></div>

                <!-- NUME -->
                <div class="mb-6">
                    <label asp-for="Nume" class="block font-semibold text-slate-700 mb-1">
                        Nume complet *
                    </label>
                    <input asp-for="Nume"
                           class="w-full px-4 py-3 border-2 border-slate-300 rounded-xl text-slate-900 focus:border-blue-600 outline-none"
                           placeholder="Ion Popescu" />
                    <span asp-validation-for="Nume" class="text-red-600"></span>
                </div>

                <!-- EMAIL -->
                <div class="mb-6">
                    <label asp-for="Email" class="block font-semibold text-slate-700 mb-1">
                        Email *
                    </label>
                    <input asp-for="Email" type="email"
                           class="w-full px-4 py-3 border-2 border-slate-300 rounded-xl text-slate-900 focus:border-blue-600 outline-none"
                           placeholder="ion@example.com" />
                    <span asp-validation-for="Email" class="text-red-600"></span>
                </div>

                <!-- SUBIECT = MESAJ -->
                <div class="mb-8">
                    <label asp-for="Subiect" class="block font-semibold text-slate-700 mb-1">
                        Mesajul tău *
                    </label>
                    <textarea asp-for="Subiect" rows="5"
                              class="w-full px-4 py-3 border-2 border-slate-300 rounded-xl text-slate-900 focus:border-blue-600 outline-none resize-y"
                              placeholder="Scrie mesajul tău aici..."></textarea>
                    <span asp-validation-for="Subiect" class="text-red-600"></span>
                </div>

                <!-- BUTTON -->
                <button type="submit"
                        class="w-full bg-blue-600 text-white font-semibold py-3 rounded-xl shadow hover:opacity-90 transition">
                    Trimite Mesaj
                </button>

            </form>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- Toast Auto-Hide Script -->
    <script>
        setTimeout(() => {
            const t = document.querySelector('.toast');
            if (t) {
                t.classList.remove('show');
                setTimeout(() => t.remove(), 300);
            }
        }, 3500);
    </script>
}
