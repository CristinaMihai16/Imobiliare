@model IEnumerable<Imobiliare.Models.Favorite>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Data_adaugare)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilizator)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Anunturi)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Data_adaugare)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Utilizator.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Anunturi.ID_Anunt)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ID_Favorite">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ID_Favorite">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ID_Favorite">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
