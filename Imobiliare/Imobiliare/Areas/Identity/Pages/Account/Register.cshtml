@page
@model RegisterModel
@{
    // Titlu și Layout
    ViewData["Title"] = "Înregistrare Cont";
    Layout = "/Views/Shared/_Layout.cshtml"; // Asigură-te că ruta către _Layout e corectă
}

<main class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            
            <h1 class="display-5 fw-bold text-secondary-modern text-center mb-4">
                Înregistrare 
            </h1>
            <p class="text-center text-muted mb-5">
                Creează-ți contul pentru a putea publica anunțuri.
            </p>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="p-5 shadow-lg rounded-4">
                
                <hr />
                
                <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-4" role="alert"></div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Nume" class="form-control" aria-required="true" placeholder="Nume" />
                            <label asp-for="Input.Nume">Nume</label>
                            <span asp-validation-for="Input.Nume" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Prenume" class="form-control" aria-required="true" placeholder="Prenume" />
                            <label asp-for="Input.Prenume">Prenume</label>
                            <span asp-validation-for="Input.Prenume" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Telefon" class="form-control" placeholder="Telefon" />
                            <label asp-for="Input.Telefon">Telefon</label>
                            <span asp-validation-for="Input.Telefon" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Adresa" class="form-control" placeholder="Adresă" />
                            <label asp-for="Input.Adresa">Adresă</label>
                            <span asp-validation-for="Input.Adresa" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <hr class="my-4" />
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Parolă</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword">Confirmă Parola</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-search-action-modern fw-bold mt-4">
                    Înregistrează-te
                </button>
                
                @if ((Model.ExternalLogins?.Count ?? 0) != 0)
                {
                    <div class="mt-4 text-center">
                        <p class="text-muted">sau folosește un serviciu extern</p>
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                            <div>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-outline-secondary me-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                                }
                            </div>
                        </form>
                    </div>
                }
            </form>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}