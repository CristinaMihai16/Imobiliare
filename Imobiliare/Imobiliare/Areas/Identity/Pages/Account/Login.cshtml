@page
@model LoginModel

@{
    ViewData["Title"] = "Autentificare";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 fade-in" style="min-height:80vh;">
    <div class="row justify-content-center">
        <div class="col-lg-5">

            <h1 class="text-center mb-4" style="color:#d63384; font-weight:800;">
                <i class="bi bi-door-open-heart"></i> Intră în cont
            </h1>
            <p class="text-center" style="color:#b565d9;">
                Bine ai revenit! Continuă să explorezi anunțurile tale preferate.
            </p>

            <div class="add-card shadow-lg mt-4">

                <form id="account" method="post">

                    <h4 class="section-title text-center mb-4">
                        <i class="bi bi-person-fill"></i> Autentificare
                    </h4>

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger text-center fw-bold mb-3">
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control add-input"
                               autocomplete="username" placeholder="email@example.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control add-input"
                               autocomplete="current-password" placeholder="parola" />
                        <label asp-for="Input.Password">Parola</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            Ține-mă minte ⭐
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="add-btn w-100 fw-bold">
                        <i class="bi bi-box-arrow-in-right"></i> Loghează-te
                    </button>

                    <hr class="my-4" />

                    <p class="text-center mb-1">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="back-link">
                            Ți-ai uitat parola?
                        </a>
                    </p>
                    <p class="text-center mb-1">
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="back-link">
                            Creează un cont nou
                        </a>
                    </p>
                    <p class="text-center">
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="back-link">
                            Retrimite emailul de confirmare
                        </a>
                    </p>

                </form>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
